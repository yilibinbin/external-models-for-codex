{
  "description": "Optional Stop-time Gemini review gate for Gemini for Codex.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GEMINI_PLUGIN_ROOT:-$CODEX_PLUGIN_ROOT}/hooks/session-lifecycle.mjs\" SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GEMINI_PLUGIN_ROOT:-$CODEX_PLUGIN_ROOT}/hooks/session-lifecycle.mjs\" SessionEnd",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GEMINI_PLUGIN_ROOT:-$CODEX_PLUGIN_ROOT}/hooks/unread-result.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GEMINI_PLUGIN_ROOT:-$CODEX_PLUGIN_ROOT}/hooks/gemini-review-gate.mjs\"",
            "timeout": 900
          }
        ]
      }
    ]
  }
}
